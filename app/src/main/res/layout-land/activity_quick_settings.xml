<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:letterSpacing="0.1"
            android:text="QUICK SETTINGS"
            android:textColor="@color/grey_444"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:layout_marginBottom="16dp" />

        <com.google.android.flexbox.FlexboxLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:flexWrap="wrap"
            app:justifyContent="flex_start">

            <TextView android:id="@+id/btnWifi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="WiFi"
                android:textColor="@color/grey_666"
                android:textSize="12sp" />

            <TextView android:id="@+id/btnData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Data"
                android:textColor="@color/grey_666"
                android:textSize="12sp" />

            <TextView android:id="@+id/btnBluetooth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Bluetooth"
                android:textColor="@color/grey_666"
                android:textSize="12sp" />

            <TextView android:id="@+id/btnFlashlightText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Flash"
                android:textColor="@color/grey_666"
                android:textSize="12sp" />
                
            <TextView android:id="@+id/btnDnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="DND"
                android:textColor="@color/grey_666"
                android:textSize="12sp" />

            <TextView android:id="@+id/btnRotate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Rotate"
                android:textColor="@color/grey_666"
                android:textSize="12sp" />

            <TextView android:id="@+id/btnAirplane"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Airplane"
                android:textColor="@color/grey_666"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView android:id="@+id/btnLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Location"
                android:textColor="@color/grey_666"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView android:id="@+id/btnHotspot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Hotspot"
                android:textColor="@color/grey_666"
                android:textSize="12sp"
                android:visibility="gone" />
        </com.google.android.flexbox.FlexboxLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginVertical="20dp"
            android:background="@color/grey_111" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="SOUND"
                    android:textColor="@color/grey_444"
                    android:textSize="9sp"
                    android:layout_marginBottom="12dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/btnSoundNormal"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="N" android:gravity="center" android:padding="10dp"
                        android:background="@drawable/bg_border_dark" android:textColor="@color/white" android:textSize="11sp" />
                    <TextView android:id="@+id/btnSoundVibrate"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="V" android:gravity="center" android:padding="10dp"
                        android:background="@drawable/bg_border_dark" android:textColor="@color/white" android:textSize="11sp" />
                    <TextView android:id="@+id/btnSoundSilent"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="M" android:gravity="center" android:padding="10dp"
                        android:background="@drawable/bg_border_dark" android:textColor="@color/white" android:textSize="11sp" />
                </LinearLayout>
                <SeekBar android:id="@+id/seekVolume"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:progressTint="@color/white" android:thumbTint="@color/white" />
            </LinearLayout>

            <View android:layout_width="24dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="DISPLAY"
                    android:textColor="@color/grey_444"
                    android:textSize="9sp"
                    android:layout_marginBottom="12dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/btnAutoBrightness"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_border_dark" android:paddingHorizontal="12dp" android:paddingVertical="8dp"
                        android:text="AUTO" android:textColor="@color/white" android:textSize="11sp" />
                    <SeekBar android:id="@+id/seekBrightness"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:layout_marginStart="8dp" android:progressTint="@color/white" android:thumbTint="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
