<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#000000"
  android:animateLayoutChanges="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="32dp">
            <View android:id="@+id/tabIndicator"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_tab_bubble"/>
            <LinearLayout android:id="@+id/tabBar"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal">
                <TextView android:id="@+id/tabStopwatch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Stopwatch" android:gravity="center" android:textColor="@color/white" android:textSize="11sp"/>
                <TextView android:id="@+id/tabTimer" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Timer" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <TextView android:id="@+id/tabStrict" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Strict" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                <TextView android:id="@+id/tabPomodoro" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Pomodoro" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </FrameLayout>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5"/>

        <!-- STOPWATCH LANDSCAPE -->
        <LinearLayout android:id="@+id/panelStopwatch"
            android:layout_width="match_parent" android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toBottomOf="parent"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView android:id="@+id/tvStopwatch"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="00:00" android:textColor="#fff" android:textSize="64sp" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans_light"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/btnSwStart" android:layout_width="140dp" android:layout_height="wrap_content" android:text="START" android:gravity="center" android:background="@drawable/bg_pill" android:backgroundTint="#fff" android:textColor="#000" android:padding="12dp" android:textSize="13sp"/>
                <TextView android:id="@+id/btnSwPause" android:layout_width="140dp" android:layout_height="wrap_content" android:text="PAUSE" android:gravity="center" android:background="@drawable/bg_pill" android:textColor="#fff" android:padding="12dp" android:textSize="11sp" android:layout_marginTop="8dp" android:visibility="gone"/>
                <TextView android:id="@+id/btnSwStop" android:layout_width="140dp" android:layout_height="wrap_content" android:text="STOP" android:gravity="center" android:background="@drawable/bg_pill" android:textColor="#888" android:padding="12dp" android:textSize="11sp" android:layout_marginTop="8dp" android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- POMODORO SETUP LANDSCAPE -->
        <ScrollView android:id="@+id/panelPomodoro"
            android:layout_width="match_parent" android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone"
            android:fillViewport="true">
            <LinearLayout android:id="@+id/pom_layoutSetup"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp">
                
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:text="DURATION" android:textColor="#444" android:textSize="9sp" android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
                        <TextView android:id="@+id/pom_btnDur25" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="25" android:gravity="center" android:background="@drawable/bg_pill" android:padding="8dp" android:textSize="12sp"/>
                        <TextView android:id="@+id/pom_btnDur50" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="50" android:gravity="center" android:background="@drawable/bg_pill" android:padding="8dp" android:textSize="12sp" android:layout_marginStart="4dp"/>
                        <TextView android:id="@+id/pom_btnDur75" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="75" android:gravity="center" android:background="@drawable/bg_pill" android:padding="8dp" android:textSize="12sp" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                    <TextView android:text="CONTACT" android:textColor="#444" android:textSize="9sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>
                    <LinearLayout android:id="@+id/pom_layoutContact" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/border_box" android:padding="8dp" android:gravity="center">
                        <TextView android:id="@+id/pom_tvContactName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+ select" android:textColor="#666" android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:layout_marginStart="16dp">
                    <TextView android:text="ALLOWED APPS" android:textColor="#444" android:textSize="9sp" android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:id="@+id/pom_slotApp1" android:layout_width="50dp" android:layout_height="50dp" android:text="+" android:gravity="center" android:background="@drawable/btn_border" android:textSize="10sp"/>
                        <TextView android:id="@+id/pom_slotApp2" android:layout_width="50dp" android:layout_height="50dp" android:text="+" android:gravity="center" android:background="@drawable/btn_border" android:textSize="10sp" android:layout_marginStart="8dp"/>
                        <TextView android:id="@+id/pom_slotApp3" android:layout_width="50dp" android:layout_height="50dp" android:text="+" android:gravity="center" android:background="@drawable/btn_border" android:textSize="10sp" android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/pom_btnStartPomodoro" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="START" android:gravity="center" android:background="@drawable/bg_pill" android:backgroundTint="#fff" android:textColor="#000" android:padding="12dp" android:layout_marginTop="16dp" android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- ACTIVE SCREEN LANDSCAPE -->
        <LinearLayout android:id="@+id/pom_layoutActive"
            android:layout_width="match_parent" android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone"
            android:orientation="horizontal" android:gravity="center">
            
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/pom_tvPhaseLabel" android:text="WORK" android:textColor="#333" android:textSize="9sp" android:letterSpacing="0.4"/>
                <TextView android:id="@+id/pom_tvCountdown" android:text="25:00" android:textColor="#fff" android:textSize="72sp" android:fontFamily="@font/plus_jakarta_sans_light"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:id="@+id/pom_active_slot1" android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/bg_pill" android:backgroundTint="#1A1A1A" android:visibility="gone"/>
                    <TextView android:id="@+id/pom_active_slot2" android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/bg_pill" android:backgroundTint="#1A1A1A" android:visibility="gone" android:layout_marginStart="8dp"/>
                    <TextView android:id="@+id/pom_active_slot3" android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/bg_pill" android:backgroundTint="#1A1A1A" android:visibility="gone" android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView android:id="@+id/pom_btnCallContact" android:layout_width="120dp" android:layout_height="wrap_content" android:text="CALL" android:gravity="center" android:background="@drawable/bg_pill" android:backgroundTint="#fff" android:textColor="#000" android:padding="10dp" android:layout_marginTop="16dp" android:visibility="gone"/>
                <TextView android:id="@+id/pom_btnEndSession" android:layout_width="120dp" android:layout_height="wrap_content" android:text="EXIT" android:gravity="center" android:background="@drawable/border_box" android:textColor="#666" android:padding="10dp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
