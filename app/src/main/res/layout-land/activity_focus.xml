<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:animateLayoutChanges="true">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.3"/>

    <!-- TAB BAR (Left Side) -->
    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/guideV">

        <LinearLayout
            android:id="@+id/tabBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView android:id="@+id/tabStopwatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Stop"
                android:textColor="@color/white"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:textSize="12sp"
                android:gravity="start"/>

            <TextView android:id="@+id/tabTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Timer"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:textSize="12sp"
                android:gravity="start"/>

            <TextView android:id="@+id/tabStrict"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Strict"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:textSize="12sp"
                android:gravity="start"/>

            <TextView android:id="@+id/tabPomodoro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Pomo"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:textSize="12sp"
                android:gravity="start"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENT AREA (Right Side) -->
    <FrameLayout
        android:id="@+id/panelContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintStart_toEndOf="@id/guideV"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- STOPWATCH PANEL -->
        <LinearLayout
            android:id="@+id/panelStopwatch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">
            <TextView android:id="@+id/tvStopwatch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#ffffff"
                android:textSize="80sp"
                android:fontFamily="@font/plus_jakarta_sans_light"/>

            <LinearLayout
                android:id="@+id/swBtnRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                <TextView android:id="@+id/btnSwStart"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="START" android:textColor="@color/black" android:fontFamily="@font/plus_jakarta_sans_extra_bold"
                    android:textSize="13sp" android:paddingHorizontal="32dp" android:paddingVertical="12dp"
                    android:background="@drawable/bg_pill" android:backgroundTint="@color/white"/>
                <TextView android:id="@+id/btnSwPause"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PAUSE" android:textColor="@color/white" android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp"
                    android:background="@drawable/bg_pill" android:visibility="gone" android:layout_marginStart="12dp"/>
                <TextView android:id="@+id/btnSwResume"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RESUME" android:textColor="@color/white" android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp"
                    android:background="@drawable/bg_pill" android:visibility="gone" android:layout_marginStart="12dp"/>
                <TextView android:id="@+id/btnSwStop"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="STOP" android:textColor="@color/text_secondary" android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp"
                    android:background="@drawable/bg_pill" android:visibility="gone" android:layout_marginStart="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- TIMER PANEL -->
        <LinearLayout
            android:id="@+id/panelTimer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            
            <LinearLayout android:id="@+id/layoutPickers"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <NumberPicker android:id="@+id/pickerHours" android:layout_width="wrap_content" android:layout_height="80dp"/>
                <NumberPicker android:id="@+id/pickerMinutes" android:layout_width="wrap_content" android:layout_height="80dp"/>
                <NumberPicker android:id="@+id/pickerSeconds" android:layout_width="wrap_content" android:layout_height="80dp"/>
            </LinearLayout>

            <TextView android:id="@+id/tvTimerCountdown"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="00:00:00" android:textColor="#ffffff" android:textSize="60sp"
                android:fontFamily="@font/plus_jakarta_sans_light" android:visibility="gone"/>

            <LinearLayout android:id="@+id/timerBtnRow"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="8dp">
                <TextView android:id="@+id/btnTimerStart"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="START" android:textColor="#888888" android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp"
                    android:background="@drawable/btn_border"/>
                <TextView android:id="@+id/btnTimerPause" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAUSE" android:textColor="#888888" android:fontFamily="@font/plus_jakarta_sans" android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/btn_border" android:visibility="gone" android:layout_marginStart="12dp"/>
                <TextView android:id="@+id/btnTimerStop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STOP" android:textColor="#888888" android:fontFamily="@font/plus_jakarta_sans" android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/btn_border" android:visibility="gone" android:layout_marginStart="12dp"/>
                <TextView android:id="@+id/btnTimerResume" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESUME" android:textColor="#888888" android:fontFamily="@font/plus_jakarta_sans" android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/btn_border" android:visibility="gone" android:layout_marginStart="12dp"/>
                <TextView android:id="@+id/btnTimerReset" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESET" android:textColor="#888888" android:fontFamily="@font/plus_jakarta_sans" android:textSize="12sp" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:background="@drawable/btn_border" android:visibility="gone" android:layout_marginStart="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- STRICT PANEL -->
        <LinearLayout
            android:id="@+id/panelStrict"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STRICT MODE"
                android:textColor="@color/white"
                android:fontFamily="@font/plus_jakarta_sans_extra_bold"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/btnEnableStrict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENABLE"
                android:textColor="#888888"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="12sp"
                android:paddingHorizontal="24dp" android:paddingVertical="10dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_border"/>
        </LinearLayout>

        <!-- POMODORO PANEL -->
        <LinearLayout
            android:id="@+id/panelPomodoro"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/pom_btnDur25" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25m" android:padding="8dp" android:background="@drawable/bg_pill" android:backgroundTint="@color/white" android:textColor="@color/black" android:textSize="11sp"/>
                <TextView android:id="@+id/pom_btnDur50" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50m" android:padding="8dp" android:background="@drawable/bg_pill" android:textColor="#666" android:textSize="11sp" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp">
                <TextView android:id="@+id/pom_slotApp1" android:layout_width="45dp" android:layout_height="45dp" android:text="+" android:gravity="center" android:background="@drawable/btn_border" android:textColor="#666"/>
                <TextView android:id="@+id/pom_slotApp2" android:layout_width="45dp" android:layout_height="45dp" android:text="+" android:gravity="center" android:background="@drawable/btn_border" android:textColor="#666" android:layout_marginStart="8dp"/>
                <TextView android:id="@+id/pom_slotApp3" android:layout_width="45dp" android:layout_height="45dp" android:text="+" android:gravity="center" android:background="@drawable/btn_border" android:textColor="#666" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView android:id="@+id/pom_btnStartPomodoro"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="START" android:textColor="@color/black" android:textSize="12sp"
                android:fontFamily="@font/plus_jakarta_sans_extra_bold" android:background="@drawable/bg_pill"
                android:backgroundTint="@color/white" android:paddingHorizontal="32dp" android:paddingVertical="10dp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <FrameLayout android:id="@+id/panelStrictActive" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000" android:visibility="gone">
             <TextView android:id="@+id/tvStrictCountdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="25:00" android:textColor="#fff" android:textSize="72sp"/>
        </FrameLayout>

    </FrameLayout>
    
    <!-- MISSING IDS FOR LANDSCAPE (Hidden to prevent crash) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        
        <View android:id="@+id/tabIndicator" android:layout_width="0dp" android:layout_height="0dp"/>
        
        <!-- Stopwatch missing -->
        <View android:id="@+id/btnSwFlag" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/scrollTimestamps" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/tvTimestamps" android:layout_width="0dp" android:layout_height="0dp"/>
        
        <!-- Timer missing -->
        <View android:id="@+id/tvTimeUp" android:layout_width="0dp" android:layout_height="0dp"/>
        
        <!-- Strict missing -->
        <View android:id="@+id/layoutStrictWarning" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/layoutStrictComplete" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/tvStrictStatus" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/btnStartAgain" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/btnExitStrict" android:layout_width="0dp" android:layout_height="0dp"/>
        
        <!-- Pomodoro missing -->
        <View android:id="@+id/pom_layoutSetup" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_layoutActive" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_btnDur75" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_btnDur100" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_tvContactName" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_btnRemoveContact" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_tvPhaseLabel" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_tvCountdown" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_tvSessionCount" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_btnCallContact" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_btnCancelBreak" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_active_slot1" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_active_slot2" android:layout_width="0dp" android:layout_height="0dp"/>
        <View android:id="@+id/pom_active_slot3" android:layout_width="0dp" android:layout_height="0dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
