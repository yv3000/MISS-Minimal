<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="CONNECTIVITY"
            android:textColor="#444444"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/btnWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WiFi"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvWifiState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnBluetooth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bluetooth"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvBluetoothState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mobile Data"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvDataState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnAirplane"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Airplane Mode"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvAirplaneState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnHotspot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Personal Hotspot"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvHotspotState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvLocationState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnRotate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto Rotate"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvRotateState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#111111"
            android:layout_marginVertical="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="APPEARANCE"
            android:textColor="#444444"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/btnFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Font Size"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvFontSizeState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14.0"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#111111"
            android:layout_marginVertical="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="SYSTEM"
            android:textColor="#444444"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/btnDnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Do Not Disturb"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvDndState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnFlashlight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Flashlight"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/plus_jakarta_sans" />
            <TextView
                android:id="@+id/tvFlashlightState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textColor="#444444"
                android:fontFamily="@font/plus_jakarta_sans" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Brightness"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/plus_jakarta_sans" />
                <TextView
                    android:id="@+id/tvBrightnessState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto"
                    android:textColor="#444444"
                    android:fontFamily="@font/plus_jakarta_sans" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seekBrightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="255"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Volume"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/plus_jakarta_sans" />
                <TextView
                    android:id="@+id/tvVolumeState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15/15"
                    android:textColor="#444444"
                    android:fontFamily="@font/plus_jakarta_sans" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seekVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="15"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginTop="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="#1a1a1a"/>

        <!-- Credits block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISS Minimal"
                android:textColor="#333333"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="11sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="built by YV"
                android:textColor="#2a2a2a"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tvTermsLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="terms &amp; conditions"
                android:textColor="#3a3a3a"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="10sp"
                android:paddingBottom="1dp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
