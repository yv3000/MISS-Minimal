<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:animateLayoutChanges="true">


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.08"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.92"/>

    <TextView
        android:id="@+id/btnExit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_pill"
        android:fontFamily="@font/plus_jakarta_sans_medium"

        android:text="EXIT"
        android:textColor="@color/white"

        android:textSize="12sp"
        android:tag="fixed_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTime"
        android:tag="fixed_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans_light"
        android:lineSpacingExtra="-8dp"
        android:text="00\n00"
        android:textColor="@color/white"
        android:textSize="85sp"
        android:gravity="center"
        android:fontFeatureSettings="tnum"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.12"
        app:layout_constraintTop_toBottomOf="@id/guideTop" />

    <TextView
        android:id="@+id/tvDate"
        android:tag="fixed_size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/plus_jakarta_sans"

        android:text="THU A 29 MARCH"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:alpha="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTime" />

    <View
        android:id="@+id/dateDivider"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="32dp"
        android:background="@color/grey_1a1a1a"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDate" />

    <TextView
        android:id="@+id/tvSOT"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="0m screen time"
        android:textColor="@color/text_secondary"
        android:tag="fixed_size"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dateDivider" />

    <LinearLayout
        android:id="@+id/appList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvSOT"
        app:layout_constraintBottom_toTopOf="@id/guideBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:tag="fixed_size"
            android:text="Phone"
            android:textColor="@color/text_secondary"

            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAppCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:tag="fixed_size"
            android:text="Camera"
            android:textColor="@color/text_secondary"

            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAppSlot1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:tag="fixed_size"
            android:text="Slot 1"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAppSlot2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:tag="fixed_size"
            android:text="Slot 2"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAppSlot3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:tag="fixed_size"
            android:text="Slot 3"
            android:textColor="@color/white"

            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_card_premium"
        android:layout_marginHorizontal="16dp"
        android:paddingVertical="4dp">


        <TextView
            android:id="@+id/btnFocus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans_medium"

            android:gravity="center"
            android:padding="16dp"
            android:text="FOCUS"
            android:textColor="@color/white"
            android:textSize="13sp"

            android:tag="fixed_size" />



        <TextView
            android:id="@+id/btnSot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans_medium"

            android:gravity="center"
            android:padding="16dp"
            android:text="SOT"
            android:textColor="@color/white"
            android:textSize="12sp"

            android:tag="fixed_size" />



        <TextView
            android:id="@+id/btnTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans_medium"

            android:gravity="center"
            android:padding="16dp"
            android:text="TIME"
            android:textColor="@color/white"
            android:textSize="13sp"

            android:tag="fixed_size" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fullscreenTimeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:id="@+id/tvFullscreenTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_light"
                android:lineSpacingExtra="-20dp"
                android:text="00\n00"
                android:textColor="#FFFFFF"
                android:textSize="140sp"
                android:gravity="center"
                android:fontFeatureSettings="tnum"
                android:tag="fixed_size" />
                
            <TextView
                android:id="@+id/tvFullscreenDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:text="DATE"
                android:textColor="#AAAAAA"
                android:textSize="18sp"
                android:tag="fixed_size" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
