<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">
    
        <!-- HEADER SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCREEN TIME"
            android:textColor="#444444"
            android:textSize="11sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textAllCaps="true"
            android:letterSpacing="0.4"/>
        
        <TextView android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THU · 03 APR"
            android:textColor="#333333"
            android:textSize="9sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginTop="4dp"/>
    
        <TextView android:id="@+id/tvTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0h 00m"
            android:textColor="#ffffff"
            android:textSize="36sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:fontWeight="200"
            android:layout_marginTop="24dp"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="total screen time today"
            android:textColor="#444444"
            android:textSize="9sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginBottom="24dp"/>
    
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#111111"
            android:layout_marginBottom="24dp"/>
    
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
    
            <ScrollView
                android:layout_width="match_parent"
                android:scrollbars="none"
                android:layout_height="match_parent">
    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
    
                    <!-- MISS MINIMAL MODES SECTION -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MISS MINIMAL"
                        android:textColor="#333333"
                        android:textSize="8sp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textAllCaps="true"
                        android:layout_marginBottom="12dp"/>
    
                    <LinearLayout android:id="@+id/layoutModes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="32dp">
                        <TextView android:id="@+id/tvNoSessions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="no sessions today"
                            android:textColor="#333333"
                            android:textSize="10sp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:gravity="center"
                            android:padding="12dp"
                            android:visibility="gone"/>
                    </LinearLayout>
    
                    <!-- APPS SECTION -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APP USAGE TODAY"
                        android:textColor="#333333"
                        android:textSize="8sp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:textAllCaps="true"
                        android:layout_marginBottom="12dp"/>
    
                    <LinearLayout android:id="@+id/layoutApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
    
            <!-- REFRESH BUTTON (overlay) -->
            <TextView android:id="@+id/btnRefresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REFRESH"
                android:textColor="#333333"
                android:textSize="9sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:padding="8dp"
                android:layout_gravity="bottom|end"/>
                
            <TextView android:id="@+id/btnGrantUsage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="#DD000000"
                android:text="Grant Usage Permission"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>

    <FrameLayout android:id="@+id/layoutSyncing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center">
            <ProgressBar
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminateTint="@color/white"
                android:layout_marginBottom="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYNCING WITH SYSTEM STATS..."
                android:textColor="#444444"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:fontFamily="@font/plus_jakarta_sans_medium"/>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
