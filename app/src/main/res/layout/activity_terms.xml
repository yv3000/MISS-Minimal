<?xml version="1.0" encoding="utf-8"?>
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#000000">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="48dp"
    android:paddingBottom="48dp">

    <!-- Back button -->
    <TextView
      android:id="@+id/btnBack"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="← back"
      android:textColor="#444444"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="11sp"
      android:layout_marginBottom="32dp"
      android:clickable="true"
      android:focusable="true"
      android:onClick="onBackPressed"/>

    <!-- Title -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="TERMS &amp; CONDITIONS"
      android:textColor="#ffffff"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="13sp"
      android:letterSpacing="0.12"
      android:layout_marginBottom="8dp"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="MISS-Minimal v2 · Open Source Launcher"
      android:textColor="#333333"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="10sp"
      android:layout_marginBottom="32dp"/>

    <!-- Divider -->
    <View
      android:layout_width="match_parent"
      android:layout_height="0.5dp"
      android:background="#1a1a1a"
      android:layout_marginBottom="28dp"/>

    <!-- Section: Open Source -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="OPEN SOURCE"
      android:textColor="#555555"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="9sp"
      android:letterSpacing="0.15"
      android:layout_marginBottom="8dp"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="MISS-Minimal v2 is a free, open source 
Android launcher. The source code is 
publicly available on GitHub. Anyone 
can view, use, or contribute to this 
project under its open source license."
      android:textColor="#888888"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="11sp"
      android:lineSpacingExtra="5dp"
      android:layout_marginBottom="28dp"/>

    <!-- Section: Privacy -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="YOUR PRIVACY"
      android:textColor="#555555"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="9sp"
      android:letterSpacing="0.15"
      android:layout_marginBottom="8dp"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="This app does not collect, store, 
transmit, or share any personal data. 
No analytics. No tracking. No servers. 
Everything stays on your device."
      android:textColor="#888888"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="11sp"
      android:lineSpacingExtra="5dp"
      android:layout_marginBottom="28dp"/>

    <!-- Section: Permissions -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="PERMISSIONS"
      android:textColor="#555555"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="9sp"
      android:letterSpacing="0.15"
      android:layout_marginBottom="8dp"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Permissions used by this app are 
required for launcher functionality only:

· Accessibility Service — blocks system 
  notification panel while launcher is active

· Device Admin — disables camera during 
  Strict Mode focus sessions only

· Do Not Disturb — silences calls and 
  notifications during Strict Mode only

· Display over other apps — keeps launcher 
  in foreground

All permissions are used locally on your 
device and for no other purpose."
      android:textColor="#888888"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="11sp"
      android:lineSpacingExtra="5dp"
      android:layout_marginBottom="28dp"/>

    <!-- Section: Disclaimer -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="DISCLAIMER"
      android:textColor="#555555"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="9sp"
      android:letterSpacing="0.15"
      android:layout_marginBottom="8dp"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="This app is provided as-is without 
any warranty. Use of Strict Mode 
features is entirely at your own risk. 
The developer is not responsible for 
any missed calls or messages during 
active focus sessions."
      android:textColor="#888888"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="11sp"
      android:lineSpacingExtra="5dp"
      android:layout_marginBottom="32dp"/>

    <!-- Divider -->
    <View
      android:layout_width="match_parent"
      android:layout_height="0.5dp"
      android:background="#1a1a1a"
      android:layout_marginBottom="28dp"/>

    <!-- Credits -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="BUILT BY"
      android:textColor="#555555"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="9sp"
      android:letterSpacing="0.15"
      android:layout_marginBottom="8dp"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="YV"
      android:textColor="#ffffff"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="18sp"
      android:fontWeight="300"
      android:layout_marginBottom="12dp"/>

    <!-- Linktree link -->
    <TextView
      android:id="@+id/tvLinktree"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="linktr.ee/yv_3000"
      android:textColor="#555555"
      android:fontFamily="@font/plus_jakarta_sans"
      android:textSize="11sp"
      android:clickable="true"
      android:focusable="true"
      android:layout_marginBottom="32dp"/>

  </LinearLayout>

</ScrollView>
