<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- SETUP SCREEN -->
    <LinearLayout
        android:id="@+id/layoutSetup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:visibility="visible"
        android:animateLayoutChanges="true">


        <!-- SECTION 1 — SESSION DURATION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SESSION"
            android:textColor="#444444"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView android:id="@+id/btnDur25"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="25 min"
                android:gravity="center"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_pill"
                android:backgroundTint="@color/apple_blue"
                android:padding="10dp"/>


            <TextView android:id="@+id/btnDur50"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="50 min"
                android:gravity="center"
                android:textColor="#666666"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_pill"
                android:layout_marginStart="8dp"
                android:padding="10dp"/>


            <TextView android:id="@+id/btnDur75"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="75 min"
                android:gravity="center"
                android:textColor="#666666"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_pill"
                android:layout_marginStart="8dp"
                android:padding="10dp"/>


            <TextView android:id="@+id/btnDur100"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="100 min"
                android:gravity="center"
                android:textColor="#666666"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_pill"
                android:layout_marginStart="8dp"
                android:padding="10dp"/>

        </LinearLayout>

        <!-- SECTION 2 — ALLOWED APPS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALLOWED APPS"
            android:textColor="#444444"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:layout_gravity="center_horizontal"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="select up to 3 apps allowed during session\n(0 is also fine — blocks everything)\nPhone calls always allowed"
            android:textColor="#444444"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView android:id="@+id/slotApp1"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="+ add"
                android:gravity="center"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="@drawable/btn_border"
                android:ellipsize="end"
                android:maxLines="1"
                android:padding="2dp"/>
            
            <TextView android:id="@+id/slotApp2"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="+ add"
                android:gravity="center"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="@drawable/btn_border"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginStart="16dp"
                android:padding="2dp"/>

            <TextView android:id="@+id/slotApp3"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="+ add"
                android:gravity="center"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="@drawable/btn_border"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginStart="16dp"
                android:padding="2dp"/>
        </LinearLayout>

        <!-- SECTION 3 — EMERGENCY CONTACT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY CONTACT"
            android:textColor="#444444"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:layout_gravity="center_horizontal"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="optional — one person you can call during session"
            android:textColor="#444444"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/layoutContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/border_box"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="40dp">
            
            <TextView android:id="@+id/tvContactName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ select contact"
                android:textColor="#666666"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp"/>
            
            <TextView android:id="@+id/btnRemoveContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="×"
                android:textColor="#888888"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- SECTION 4 — START BUTTON -->
        <TextView android:id="@+id/btnStartPomodoro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="START POMODORO"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:background="@drawable/bg_pill"
            android:backgroundTint="@color/spotify_green"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"/>


    </LinearLayout>

    <!-- WORK/BREAK SCREEN -->
    <LinearLayout
        android:id="@+id/layoutActive"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView android:id="@+id/tvPhaseLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="POMODORO"
            android:textColor="#333333"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:letterSpacing="0.4"
            android:tag="fixed_size"
            android:layout_marginBottom="12dp"/>

        <TextView android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textColor="#ffffff"
            android:textSize="72sp"
            android:fontFamily="sans-serif-light"
            android:fontWeight="200"
            android:tag="fixed_size"/>


        <TextView android:id="@+id/tvSessionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="session 1 of ∞"
            android:textColor="#444444"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:tag="fixed_size"
            android:layout_marginTop="12dp"/>

        <!-- Contact Button -->
        <TextView android:id="@+id/btnCallContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CALL CONTACT"
            android:textColor="#888888"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:background="@drawable/btn_border"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginTop="32dp"
            android:visibility="gone"/>

        <!-- Cancel (Only during break) -->
        <TextView android:id="@+id/btnCancelBreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCEL SESSION"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:background="@drawable/btn_border"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="32dp"
            android:visibility="gone"/>

    </LinearLayout>

</FrameLayout>
