<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.08"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.92"/>

    <LinearLayout
        android:id="@+id/tabsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/guideTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:id="@+id/tabStopwatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[STOPWATCH]"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="16dp" />
        <TextView
            android:id="@+id/tabTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[TIMER]"
            android:textColor="#666666"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="16dp" />
        <TextView
            android:id="@+id/tabStrict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[STRICT]"
            android:textColor="#666666"
            android:textSize="16sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabsLayout"
        app:layout_constraintBottom_toTopOf="@id/guideBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutStopwatch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="52sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="FOCUS SESSION"
                android:textColor="#333333"
                android:textSize="9sp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView
                    android:id="@+id/btnStopwatchStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="START"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/btnStopwatchPause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="PAUSE"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/btnStopwatchResume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="RESUME"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/btnStopwatchStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="STOP"
                    android:textColor="#FF5555"
                    android:textSize="12sp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTimer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutTimerInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                <NumberPicker
                    android:id="@+id/pickerHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="monospace"
                    android:text="H"
                    android:textColor="#555555"
                    android:textSize="24sp" />

                <NumberPicker
                    android:id="@+id/pickerMinutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="16dp"
                    android:fontFamily="monospace"
                    android:text="M"
                    android:textColor="#555555"
                    android:textSize="24sp" />

                <NumberPicker
                    android:id="@+id/pickerSeconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="monospace"
                    android:text="S"
                    android:textColor="#555555"
                    android:textSize="24sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTimerDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="00:00:00"
                android:textColor="#FFFFFF"
                android:textSize="52sp"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvTimeUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIME UP"
                android:textColor="#FF5555"
                android:textSize="32sp"
                android:fontFamily="monospace"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView
                    android:id="@+id/btnTimerStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="START"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/btnTimerPause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="PAUSE"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/btnTimerResume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="RESUME"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/btnTimerStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="STOP"
                    android:textColor="#FF5555"
                    android:textSize="12sp"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/btnTimerReset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_dark"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="RESET"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStrict"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="32dp">

            <LinearLayout
                android:id="@+id/boxStrictWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_border_dark"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStrictModeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="STRICT MODE"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvStrictStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="Enabling this will silence all calls, messages and notifications for 25 minutes.\n\nAll distractions will be blocked.\n\nOnly enable if fully committed to your task.\n\nUse at your own risk."
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvStrictCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="25:00"
                android:textColor="#FFFFFF"
                android:textSize="72sp"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/btnEnableStrict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_border_dark"
                android:fontFamily="monospace"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                android:text="ENABLE STRICT MODE"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
