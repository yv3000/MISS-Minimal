<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- CONNECTIVITY -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:letterSpacing="0.1"
        android:text="CONNECTIVITY"
        android:textColor="@color/grey_444"
        android:textSize="8sp"
        android:textAllCaps="true"
        android:layout_marginBottom="16dp" />

    <com.google.android.flexbox.FlexboxLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:flexWrap="wrap">

        <TextView
            android:id="@+id/btnWifi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_border_dark"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="WiFi"
            android:textColor="@color/grey_666"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_border_dark"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Data"
            android:textColor="@color/grey_666"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnBluetooth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_border_dark"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Bluetooth"
            android:textColor="@color/grey_666"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/btnFlashlight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_border_dark"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:src="@drawable/ic_flashlight"
            app:tint="@color/grey_666" />
            
        <TextView
            android:id="@+id/btnDnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_border_dark"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="DND"
            android:textColor="@color/grey_666"
            android:textSize="12sp" />
    </com.google.android.flexbox.FlexboxLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginVertical="24dp"
        android:background="@color/grey_111" />

    <!-- SOUND -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:letterSpacing="0.1"
        android:text="SOUND"
        android:textColor="@color/grey_444"
        android:textSize="8sp"
        android:textAllCaps="true"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/btnSoundNormal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Norm"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/bg_border_dark"
            android:textColor="@color/white"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/btnSoundVibrate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Vib"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/bg_border_dark"
            android:textColor="@color/white"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/btnSoundSilent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Mute"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/bg_border_dark"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="VOL"
            android:textColor="@color/grey_aaa"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/seekVolume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:progressTint="@color/white"
            android:thumbTint="@color/white" />
        <TextView
            android:id="@+id/tvVolumeVal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="100%"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginVertical="24dp"
        android:background="@color/grey_111" />

    <!-- DISPLAY -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/plus_jakarta_sans"
        android:letterSpacing="0.1"
        android:text="DISPLAY"
        android:textColor="@color/grey_444"
        android:textSize="8sp"
        android:textAllCaps="true"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/btnAutoBrightness"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_border_dark"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="AUTO"
            android:textColor="@color/white"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/seekBrightness"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:progressTint="@color/white"
            android:thumbTint="@color/white"
            android:max="255" />
    </LinearLayout>

</LinearLayout>
