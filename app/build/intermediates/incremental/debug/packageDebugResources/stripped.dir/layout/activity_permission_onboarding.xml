<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STRICT MODE SETUP"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:text="Grant these permissions to lock your phone during focus sessions."
        android:textColor="#666666"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvSubtitle"
        android:layout_above="@id/btnContinue"
        android:layout_marginBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Step 1: Accessibility -->
            <LinearLayout
                android:id="@+id/rowAccessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accessibility Permission"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Required to block apps during focus"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnAllowAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/btn_border"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tvStatusAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Granted"
                    android:visibility="gone"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1a1a1a"/>

            <!-- Step 2: Usage Stats -->
            <LinearLayout
                android:id="@+id/rowUsage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usage Permission"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allows tracking which app is open"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnAllowUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/btn_border"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tvStatusUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Granted"
                    android:visibility="gone"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1a1a1a"/>

            <!-- Step 2.5: Notification Listener -->
            <LinearLayout
                android:id="@+id/rowNotificationListener"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification Access"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Required to intercept notifications"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnAllowNotifListener"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/btn_border"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tvStatusNotifListener"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Granted"
                    android:visibility="gone"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1a1a1a"/>

            <!-- Step 3: Overlay -->
            <LinearLayout
                android:id="@+id/rowOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Display over other apps"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Needed to show focus overlay"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnAllowOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/btn_border"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tvStatusOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Granted"
                    android:visibility="gone"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1a1a1a"/>

            <!-- Step 4: DND -->
            <LinearLayout
                android:id="@+id/rowDnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Do Not Disturb"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Silences calls during strict mode"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnAllowDnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/btn_border"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tvStatusDnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Granted"
                    android:visibility="gone"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1a1a1a"/>

            <!-- Step 5: Battery -->
            <LinearLayout
                android:id="@+id/rowBattery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background permission"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keeps strict mode running in background"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnAllowBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/btn_border"
                    android:gravity="center"/>
                <TextView
                    android:id="@+id/tvStatusBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Granted"
                    android:visibility="gone"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1a1a1a"/>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/btn_border"
        android:text="CONTINUE"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:alpha="0.4"
        android:enabled="false"
        android:textSize="16sp"
        android:textStyle="bold"/>

</RelativeLayout>
